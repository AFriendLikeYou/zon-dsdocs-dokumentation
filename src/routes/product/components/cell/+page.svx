<\/script>

<article class="z-cell z-cell--{type}" class:z-cell--small={size === 'small'}>
  <div class="z-cell__media" aria-hidden="true"></div>
  <div class="z-cell__body">
    <p class="z-cell__kicker">Politik</p>
    <h3 class="z-cell__title">Artikel Überschrift</h3>
