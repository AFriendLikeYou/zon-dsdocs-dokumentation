ke-width=\"1.5\"/></svg></button>\n    <button class=\"z-carousel__direction-button z-carousel__direction-button--next\" aria-label=\"Nächste Seite\"><svg class=\"z-carousel__direction-icon\" viewBox=\"0 0 14 14\" aria-hidden=\"true\"><path d=\"M5 2l5 5-5 5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"/></svg></button>\n  </div>\n  <div class=\"z-carousel__tabpanel-control-wrapper\" role=\"group\" aria-label=\"Seitensteuerung\">\n    <fieldset class=\"z-carousel__dots-wrapper\" role=\"tablist\" aria-label=\"Seite auswählen\">\n      <input class=\"z-carousel__dot\" type=\"radio\" name=\"pg-carousel\" role=\"tab\" id=\"pg-c-tab-1\" aria-controls=\"pg-c-panel-1\" aria-label=\"Seite 1\" aria-selected=\"true\" checked>\n      <input class=\"z-carousel__dot\" type=\"radio\" name=\"pg-carousel\" role=\"tab\" id=\"pg-c-tab-2\" aria-controls=\"pg-c-panel-2\" aria-label=\"Seite 2\" aria-selected=\"false\">\n      <input class=\"z-carousel__dot\" type=\"radio\" name=\"pg-carousel\" role=\"tab\" id=\"pg-c-tab-3\" aria-controls=\"pg-c-panel-3\" aria-label=\"Seite 3\" aria-selected=\"false\">\n      <input class=\"z-carousel__dot\" type=\"radio\" name=\"pg-carousel\" role=\"tab\" id=\"pg-c-tab-4\" aria-controls=\"pg-c-panel-4\" aria-label=\"Seite 4\" aria-selected=\"false\">\n    </fieldset>\n  </div>\n</div>","note":"Breite Slots (20rem) für Produkt-/Shop-Kacheln; getönter Fader-Ton."},{"label":"controls (Figma-Prop, default an)","html":"<div class=\"z-carousel\" role=\"group\" aria-roledescription=\"Karussell\" aria-label=\"Beispiel-Karussell\">\n  <div class=\"z-carousel__scroll-container\" tabindex=\"-1\" aria-live=\"polite\">\n    <div class=\"z-carousel__slide\" role=\"tabpanel\" id=\"pg-c-panel-1\" aria-labelledby=\"pg-c-tab-1\">Slot 1</div>\n    <div class=\"z-carousel__slide\" role=\"tabpanel\" id=\"pg-c-panel-2\" aria-labelledby=\"pg-c-tab-2\">Slot 2</div>\n    <div class=\"z-carousel__slide\" role=\"tabpanel\" id=\"pg-c-panel-3\" aria-labelledby=\"pg-c-tab-3\">Slot 3</div>\n    <div class=\"z-carousel__slide\" role=\"tabpanel\" id=\"pg-c-panel-4\" aria-labelledby=\"pg-c-tab-4\">Slot 4</div>\n  </div>\n  <div class=\"z-carousel__slide-control-wrapper\" role=\"group\" aria-label=\"Steuerelemente\">\n    <button class=\"z-carousel__direction-button z-carousel__direction-button--previous\" aria-label=\"Vorige Seite\" disabled><svg class=\"z-carousel__direction-icon\" viewBox=\"0 0 14 14\" aria-hidden=\"true\"><path d=\"M9 2 4 7l5 5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"/></svg></button>\n    <button class=\"z-carousel__direction-button z-carousel__direction-button--next\" aria-label=\"Nächste Seite\"><svg class=\"z-carousel__direction-icon\" viewBox=\"0 0 14 14\" aria-hidden=\"true\"><path d=\"M5 2l5 5-5 5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"/></svg></button>\n  </div>\n  <div class=\"z-carousel__tabpanel-control-wrapper\" role=\"group\" aria-label=\"Seitensteuerung\">\n    <fieldset class=\"z-carousel__dots-wrapper\" role=\"tablist\" aria-label=\"Seite auswählen\">\n      <input class=\"z-carousel__dot\" type=\"radio\" name=\"pg-carousel\" role=\"tab\" id=\"pg-c-tab-1\" aria-controls=\"pg-c-panel-1\" aria-label=\"Seite 1\" aria-selected=\"true\" checked>\n      <input class=\"z-carousel__dot\" type=\"radio\" name=\"pg-carousel\" role=\"tab\" id=\"pg-c-tab-2\" aria-controls=\"pg-c-panel-2\" aria-label=\"Seite 2\" aria-selected=\"false\">\n      <input class=\"z-carousel__dot\" type=\"radio\" name=\"pg-carousel\" role=\"tab\" id=\"pg-c-tab-3\" aria-controls=\"pg-c-panel-3\" aria-label=\"Seite 3\" aria-selected=\"false\">\n      <input class=\"z-carousel__dot\" type=\"radio\" name=\"pg-carousel\" role=\"tab\" id=\"pg-c-tab-4\" aria-controls=\"pg-c-panel-4\" aria-label=\"Seite 4\" aria-selected=\"false\">\n    </fieldset>\n  </div>\n</div>"},{"label":"no-controls","html":"<div class=\"z-carousel z-carousel--no-controls\" role=\"group\" aria-roledescription=\"Karussell\" aria-label=\"Beispiel-Karussell\">\n  <div class=\"z-carousel__scroll-container\" tabindex=\"-1\" aria-live=\"polite\">\n    <div class=\"z-carousel__slide\" role=\"tabpanel\" id=\"pg-c-panel-1\" aria-labelledby=\"pg-c-tab-1\">Slot 1</div>\n    <div class=\"z-carousel__slide\" role=\"tabpanel\" id=\"pg-c-panel-2\" aria-labelledby=\"pg-c-tab-2\">Slot 2</div>\n    <div class=\"z-carousel__slide\" role=\"tabpanel\" id=\"pg-c-panel-3\" aria-labelledby=\"pg-c-tab-3\">Slot 3</div>\n    <div class=\"z-carousel__slide\" role=\"tabpanel\" id=\"pg-c-panel-4\" aria-labelledby=\"pg-c-tab-4\">Slot 4</div>\n  </div>\n  <div class=\"z-carousel__slide-control-wrapper\" role=\"group\" aria-label=\"Steuerelemente\">\n    <button class=\"z-carousel__direction-button z-carousel__direction-button--previous\" aria-label=\"Vorige Seite\" disabled><svg class=\"z-carousel__direction-icon\" viewBox=\"0 0 14 14\" aria-hidden=\"true\"><path d=\"M9 2 4 7l5 5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"/></svg></button>\n    <button class=\"z-carousel__direction-button z-carousel__direction-button--next\" aria-label=\"Nächste Seite\"><svg class=\"z-carousel__direction-icon\" viewBox=\"0 0 14 14\" aria-hidden=\"true\"><path d=\"M5 2l5 5-5 5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"/></svg></button>\n  </div>\n  <div class=\"z-carousel__tabpanel-control-wrapper\" role=\"group\" aria-label=\"Seitensteuerung\">\n    <fieldset class=\"z-carousel__dots-wrapper\" role=\"tablist\" aria-label=\"Seite auswählen\">\n      <input class=\"z-carousel__dot\" type=\"radio\" name=\"pg-carousel\" role=\"tab\" id=\"pg-c-tab-1\" aria-controls=\"pg-c-panel-1\" aria-label=\"Seite 1\" aria-selected=\"true\" checked>\n      <input class=\"z-carousel__dot\" type=\"radio\" name=\"pg-carousel\" role=\"tab\" id=\"pg-c-tab-2\" aria-controls=\"pg-c-panel-2\" aria-label=\"Seite 2\" aria-selected=\"false\">\n      <input class=\"z-carousel__dot\" type=\"radio\" name=\"pg-carousel\" role=\"tab\" id=\"pg-c-tab-3\" aria-controls=\"pg-c-panel-3\" aria-label=\"Seite 3\" aria-selected=\"false\">\n      <input class=\"z-carousel__dot\" type=\"radio\" name=\"pg-carousel\" role=\"tab\" id=\"pg-c-tab-4\" aria-controls=\"pg-c-panel-4\" aria-label=\"Seite 4\" aria-selected=\"false\">\n    </fieldset>\n  </div>\n</div>","note":"Reine Scroll-Leiste ohne Pfeile/Dots (Figma-Prop Controls=false)."},{"label":"overlay-controls","html":"<div class=\"z-carousel z-carousel--overlay-controls\" role=\"group\" aria-roledescription=\"Karussell\" aria-label=\"Beispiel-Karussell\">\n  <div class=\"z-carousel__scroll-container\" tabindex=\"-1\" aria-live=\"polite\">\n    <div class=\"z-carousel__slide\" role=\"tabpanel\" id=\"pg-c-panel-1\" aria-labelledby=\"pg-c-tab-1\">Slot 1</div>\n    <div class=\"z-carousel__slide\" role=\"tabpanel\" id=\"pg-c-panel-2\" aria-labelledby=\"pg-c-tab-2\">Slot 2</div>\n    <div class=\"z-carousel__slide\" role=\"tabpanel\" id=\"pg-c-panel-3\" aria-labelledby=\"pg-c-tab-3\">Slot 3</div>\n    <div class=\"z-carousel__slide\" role=\"tabpanel\" id=\"pg-c-panel-4\" aria-labelledby=\"pg-c-tab-4\">Slot 4</div>\n  </div>\n  <div class=\"z-carousel__slide-control-wrapper\" role=\"group\" aria-label=\"Steuerelemente\">\n    <button class=\"z-carousel__direction-button z-carousel__direction-button--previous\" aria-label=\"Vorige Seite\" disabled><svg class=\"z-carousel__direction-icon\" viewBox=\"0 0 14 14\" aria-hidden=\"true\"><path d=\"M9 2 4 7l5 5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"/></svg></button>\n    <button class=\"z-carousel__direction-button z-carousel__direction-button--next\" aria-label=\"Nächste Seite\"><svg class=\"z-carousel__direction-icon\" viewBox=\"0 0 14 14\" aria-hidden=\"true\"><path d=\"M5 2l5 5-5 5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"/></svg></button>\n  </div>\n  <div class=\"z-carousel__tabpanel-control-wrapper\" role=\"group\" aria-label=\"Seitensteuerung\">\n    <fieldset class=\"z-carousel__dots-wrapper\" role=\"tablist\" aria-label=\"Seite auswählen\">\n      <input class=\"z-carousel__dot\" type=\"radio\" name=\"pg-carousel\" role=\"tab\" id=\"pg-c-tab-1\" aria-controls=\"pg-c-panel-1\" aria-label=\"Seite 1\" aria-selected=\"true\" checked>\n      <input class=\"z-carousel__dot\" type=\"radio\" name=\"pg-carousel\" role=\"tab\" id=\"pg-c-tab-2\" aria-controls=\"pg-c-panel-2\" aria-label=\"Seite 2\" aria-selected=\"false\">\n      <input class=\"z-carousel__dot\" type=\"radio\" name=\"pg-carousel\" role=\"tab\" id=\"pg-c-tab-3\" aria-controls=\"pg-c-panel-3\" aria-label=\"Seite 3\" aria-selected=\"false\">\n      <input class=\"z-carousel__dot\" type=\"radio\" name=\"pg-carousel\" role=\"tab\" id=\"pg-c-tab-4\" aria-controls=\"pg-c-panel-4\" aria-label=\"Seite 4\" aria-selected=\"false\">\n    </fieldset>\n  </div>\n</div>","note":"Pfeile über den Rand-Zonen statt darunter; ≥48em erst auf hover sichtbar."},{"label":"autoplay","html":"<div class=\"z-carousel z-carousel--autoplay\" role=\"group\" aria-roledescription=\"Karussell\" aria-label=\"Beispiel-Karussell\">\n  <div class=\"z-carousel__scroll-container\" tabindex=\"-1\" aria-live=\"polite\">\n    <div class=\"z-carousel__slide\" role=\"tabpanel\" id=\"pg-c-panel-1\" aria-labelledby=\"pg-c-tab-1\">Slot 1</div>\n    <div class=\"z-carousel__slide\" role=\"tabpanel\" id=\"pg-c-panel-2\" aria-labelledby=\"pg-c-tab-2\">Slot 2</div>\n    <div class=\"z-carousel__slide\" role=\"tabpanel\" id=\"pg-c-panel-3\" aria-labelledby=\"pg-c-tab-3\">Slot 3</div>\n    <div class=\"z-carousel__slide\" role=\"tabpanel\" id=\"pg-c-panel-4\" aria-labelledby=\"pg-c-tab-4\">Slot 4</div>\n  </div>\n  <div class=\"z-carousel__slide-control-wrapper\" role=\"group\" aria-label=\"Steuerelemente\">\n    <button class=\"z-carousel__direction-button z-carousel__direction-button--previous\" aria-label=\"Vorige Seite\" disabled><svg class=\"z-carousel__direction-icon\" viewBox=\"0 0 14 14\" aria-hidden=\"true\"><path d=\"M9 2 4 7l5 5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"/></svg></button>\n    <button class=\"z-carousel__direction-button z-carousel__direction-button--next\" aria-label=\"Nächste Seite\"><svg class=\"z-carousel__direction-icon\" viewBox=\"0 0 14 14\" aria-hidden=\"true\"><path d=\"M5 2l5 5-5 5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"/></svg></button>\n  </div>\n  <div class=\"z-carousel__tabpanel-control-wrapper\" role=\"group\" aria-label=\"Seitensteuerung\">\n    <fieldset class=\"z-carousel__dots-wrapper\" role=\"tablist\" aria-label=\"Seite auswählen\">\n      <input class=\"z-carousel__dot\" type=\"radio\" name=\"pg-carousel\" role=\"tab\" id=\"pg-c-tab-1\" aria-controls=\"pg-c-panel-1\" aria-label=\"Seite 1\" aria-selected=\"true\" checked>\n      <input class=\"z-carousel__dot\" type=\"radio\" name=\"pg-carousel\" role=\"tab\" id=\"pg-c-tab-2\" aria-controls=\"pg-c-panel-2\" aria-label=\"Seite 2\" aria-selected=\"false\">\n      <input class=\"z-carousel__dot\" type=\"radio\" name=\"pg-carousel\" role=\"tab\" id=\"pg-c-tab-3\" aria-controls=\"pg-c-panel-3\" aria-label=\"Seite 3\" aria-selected=\"false\">\n      <input class=\"z-carousel__dot\" type=\"radio\" name=\"pg-carousel\" role=\"tab\" id=\"pg-c-tab-4\" aria-controls=\"pg-c-panel-4\" aria-label=\"Seite 4\" aria-selected=\"false\">\n    </fieldset>\n  </div>\n</div>","note":"Automatischer Wechsel mit Fortschritts-Dot und Play/Pause-Steuerung."}];
	const offeneVariantItems = variantItems.filter((it) => !abgedeckteVarianten.has(it.label));
	const propsData = [{"name":"view-mode","typ":"\"default\" | \"single\" | \"continuous\"","default":"\"default\"","beschreibung":"single = eine Slide je Ansicht (kein Gap/Padding); continuous = freies Scrollen ohne Snap.","erlaubteWerte":["single","continuous"]},{"name":"variant","typ":"\"kiosk\" | \"shop\" | \"merkl\"","default":"—","beschreibung":"kiosk = feste schmale Slot-Breite (12.25rem); shop = breite Slots (20rem), getönter Fader.","erlaubteWerte":["kiosk","shop"]},{"name":"overlay-controls","typ":"boolean-Attribut","default":"false","beschreibung":"Pfeile liegen über den linken/rechten Rand-Zonen (Overlay) statt in der Control-Zeile; ≥48em auf hover eingeblendet."},{"name":"autoplay","typ":"boolean-Attribut","default":"false","beschreibung":"Automatischer Wechsel; aktiver Dot zeigt einen animierten Fortschritt. Play/Pause-Button steuert die Wiedergabe."},{"name":"controls","typ":"boolean (Figma-Prop)","default":"true","beschreibung":"Blendet die Slider-Controls (Progress-Dots + Pfeile) ein/aus."}];
</script>

<svelte:head>
	<title>{title} - Die Zeit Design System</title>
</svelte:head>

# {title}

<ComponentHero spec={spec} version={content.version} />

<Tabs tabs={[
		{ id: 'designTab', label: 'Design', component: designTab },
		{ id: 'developTab', label: 'Develop', component: developTab },
		...((spec.a11y?.length || spec.tastatur?.length) ? [{ id: 'a11yTab', label: 'Barrierefreiheit', component: a11yTab }] : []),
		{ id: 'specsTab', label: 'Specs', component: specsTab }
]} sticky />

{#snippet designTab()}
	<h2 id="playground" class="section-anchor">Playground</h2>
	<Playground controls={playgroundControls} template={playgroundTemplate} align={spec.playground?.align} resizable={spec.playground?.resizable} />

	{#if beispiele.length}
		<h2 id="beispiele" class="section-anchor">Beispiele</h2>
		{#each beispiele as beispiel, i (i)}
			<ExampleBlock
				titel={beispiel.titel}
				beschreibung={beispiel.beschreibung}
				instanzen={(beispiel.instanzen ?? [{}]).map((werte) =>
					instantiate(playgroundTemplate, playgroundControls, werte)
				)}
			/>
		{/each}
	{/if}

	<h2 id="anatomie" class="section-anchor">Anatomie</h2>
	<Anatomy masse={spec.masse} spacing={spec.spacing} callouts={spec.callouts} {calloutAnchors}>
		{#snippet preview()}<div class="z-carousel"><div class="z-carousel__scroll-container"><div class="z-carousel__slide">Slot 1</div><div class="z-carousel__slide">Slot 2</div><div class="z-carousel__slide">Slot 3</div></div><div class="z-carousel__dots-wrapper" role="radiogroup" aria-label="Slide-Auswahl"><input class="z-carousel__dot" type="radio" name="pv-carousel" aria-label="Slide 1" checked><input class="z-carousel__dot" type="radio" name="pv-carousel" aria-label="Slide 2"><input class="z-carousel__dot" type="radio" name="pv-carousel" aria-label="Slide 3"></div></div>{/snippet}
	</Anatomy>

	{#if spec.verwendung?.nutzen?.length || spec.verwendung?.nichtNutzen?.length}
		<h2 id="verwendung" class="section-anchor">Verwendung</h2>
		<UsageBlock verwendung={spec.verwendung} />
	{/if}

	{#if spec.wording?.length}
		<h2 id="wording" class="section-anchor">Texte &amp; Wording</h2>
		<WordingList items={spec.wording} />
	{/if}

	{#if offeneVariantItems.length}
		<h2 id="varianten" class="section-anchor">
			{abgedeckteVarianten.size ? 'Weitere Varianten' : 'Varianten'}
		</h2>
		<SpecimenGrid items={offeneVariantItems} />
	{/if}

	<h2 id="zustaende" class="section-anchor">Zustände</h2>
	<StateList states={[{"label":"default","vorhanden":true},{"label":"hover (Pfeile/Dots)"},{"label":"focus-visible"},{"label":"disabled (Pfeile am Rand)"},{"label":"checked (aktiver Dot)"}]} hint="Statisch nicht darstellbar (reine Pseudoklassen) — im Playground per Interaktion sichtbar." />

	{#if spec.doDont?.do?.length || spec.doDont?.dont?.length}
		<h2 id="do-dont" class="section-anchor">Do & Don't</h2>
		<DoDontList doDont={spec.doDont} />
	{/if}

	{#if spec.verwandt?.length}
		<h2 id="verwandte" class="section-anchor">Verwandte Komponenten</h2>
		<RelatedComponents slugs={spec.verwandt} />
	{/if}
{/snippet}

{#snippet developTab()}
	<h2>Properties</h2>
	<PropsTable props={propsData} />

	<h2>Code</h2>
	<CodeBlock title="HTML" lang="html" code={htmlCode} />
	<CodeBlock title="CSS · Pattern (pattern.css)" lang="css" code={patternCssCode} />

	{#if (editorial.codeBeispiele ?? []).length}
		<h2>Redaktionelle Code-Beispiele</h2>
		{#each editorial.codeBeispiele ?? [] as beispiel, i (i)}
			<h3>{beispiel.label}</h3>
			{#if beispiel.hinweis}<p>{beispiel.hinweis}</p>{/if}
			<CodeBlock lang={beispiel.sprache ?? 'svelte'} code={beispiel.code} />
		{/each}
	{/if}
{/snippet}

{#snippet a11yTab()}
	{#if spec.a11y?.length}
		<A11yList items={spec.a11y} />
	{/if}

	{#if spec.tastatur?.length}
		<h2>Tastatur</h2>
		<KeyboardList items={spec.tastatur} />
	{/if}
{/snippet}

{#snippet specsTab()}
	<h2>Maße</h2>
	<MeasureTable masse={spec.masse} />

	<h2>Farbrollen</h2>
	<ColorRoleTable farbrollen={spec.farbrollen} />

	<h2>Tokens</h2>
	<TokenTable tokens={spec.tokens} />
{/snippet}

<style>
:global(.spec-canvas .z-carousel),
:global(.pg-preview .z-carousel) {
  --_z-carousel-padding-inline: 54px; 
	--_z-carousel-button-bg: var(--z-ds-color-background-10);
	--_z-carousel-button-bg-hover: var(--z-ds-color-background-20);
	--_z-carousel-button-fg: var(--z-ds-color-text-70);
	--_z-carousel-slide-gap: var(--z-ds-space-m);
	--_z-carousel-slide-width: calc(320 / 892 * 100%); 
	--_z-carousel-button-size: 1.875rem; 
	--_z-carousel-icon-size: 0.875rem; 
	display: grid;
	grid-template-areas: 'left middle right';
	grid-template-columns: var(--_z-carousel-padding-inline) 1fr var(--_z-carousel-padding-inline);
	margin-bottom: var(--z-ds-space-l);
	row-gap: var(--z-ds-space-m);
	font-family: 'Tablet Gothic', 'ZEIT Sans', system-ui, sans-serif;
}
:global(.spec-canvas .z-carousel__scroll-container),
:global(.pg-preview .z-carousel__scroll-container) {
  display: flex;
	gap: var(--_z-carousel-slide-gap);
	grid-area: 1 / 1 / 2 / -1;
	overflow: auto hidden;
	padding-inline: var(--_z-carousel-padding-inline);
	position: relative;
	scroll-padding-left: var(--_z-carousel-padding-inline);
	scroll-snap-type: x mandatory;
	scroll-behavior: smooth;
}
:global(.spec-canvas .z-carousel__scroll-container > *),
:global(.pg-preview .z-carousel__scroll-container > *) {
  flex: 0 0 var(--_z-carousel-slide-width);
	scroll-snap-align: start;
}
:global(.spec-canvas .z-carousel__slide),
:global(.pg-preview .z-carousel__slide) {
  aspect-ratio: 1 / 1;
	border-radius: var(--z-ds-border-radius-4);
