		"template": "<div class=\"z-carousel{classes}\"{attrs} role=\"group\" aria-roledescription=\"Karussell\" aria-label=\"Beispiel-Karussell\">\n  <div class=\"z-carousel__scroll-container\" tabindex=\"-1\" aria-live=\"polite\">\n    <div class=\"z-carousel__slide\" role=\"tabpanel\" id=\"pg-c-panel-1\" aria-labelledby=\"pg-c-tab-1\">Slot 1</div>\n    <div class=\"z-carousel__slide\" role=\"tabpanel\" id=\"pg-c-panel-2\" aria-labelledby=\"pg-c-tab-2\">Slot 2</div>\n    <div class=\"z-carousel__slide\" role=\"tabpanel\" id=\"pg-c-panel-3\" aria-labelledby=\"pg-c-tab-3\">Slot 3</div>\n    <div class=\"z-carousel__slide\" role=\"tabpanel\" id=\"pg-c-panel-4\" aria-labelledby=\"pg-c-tab-4\">Slot 4</div>\n  </div>\n  <div class=\"z-carousel__slide-control-wrapper\" role=\"group\" aria-label=\"Steuerelemente\">\n    <button class=\"z-carousel__direction-button z-carousel__direction-button--previous\" aria-label=\"Vorige Seite\" disabled><svg class=\"z-carousel__direction-icon\" viewBox=\"0 0 14 14\" aria-hidden=\"true\"><path d=\"M9 2 4 7l5 5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"/></svg></button>\n    <button class=\"z-carousel__direction-button z-carousel__direction-button--next\" aria-label=\"Nächste Seite\"><svg class=\"z-carousel__direction-icon\" viewBox=\"0 0 14 14\" aria-hidden=\"true\"><path d=\"M5 2l5 5-5 5\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.5\"/></svg></button>\n  </div>\n  <div class=\"z-carousel__tabpanel-control-wrapper\" role=\"group\" aria-label=\"Seitensteuerung\">\n    <fieldset class=\"z-carousel__dots-wrapper\" role=\"tablist\" aria-label=\"Seite auswählen\">\n      <input class=\"z-carousel__dot\" type=\"radio\" name=\"pg-carousel\" role=\"tab\" id=\"pg-c-tab-1\" aria-controls=\"pg-c-panel-1\" aria-label=\"Seite 1\" aria-selected=\"true\" checked>\n      <input class=\"z-carousel__dot\" type=\"radio\" name=\"pg-carousel\" role=\"tab\" id=\"pg-c-tab-2\" aria-controls=\"pg-c-panel-2\" aria-label=\"Seite 2\" aria-selected=\"false\">\n      <input class=\"z-carousel__dot\" type=\"radio\" name=\"pg-carousel\" role=\"tab\" id=\"pg-c-tab-3\" aria-controls=\"pg-c-panel-3\" aria-label=\"Seite 3\" aria-selected=\"false\">\n      <input class=\"z-carousel__dot\" type=\"radio\" name=\"pg-carousel\" role=\"tab\" id=\"pg-c-tab-4\" aria-controls=\"pg-c-panel-4\" aria-label=\"Seite 4\" aria-selected=\"false\">\n    </fieldset>\n  </div>\n</div>",
