	const offeneVariantItems = variantItems.filter((it) => !abgedeckteVarianten.has(it.label));
	const propsData = [{"name":"style","typ":"\"Standard\" | \"Centered\" | \"Split\" | \"Longform\"","default":"\"Standard\"","beschreibung":"Stil-Achse — steuert Anordnung, Schrift und Farbgebung."},{"name":"panorama","typ":"boolean","default":"false","beschreibung":"Randlose Ausspielung über die volle Seitenbreite (zon-teaser--is-panorama)."},{"name":"kicker","typ":"string","beschreibung":"Spitzmarke — Ressort oder Thema."},{"name":"title","typ":"string","pflicht":true,"beschreibung":"Artikel-Überschrift."},{"name":"summary","typ":"string","beschreibung":"Zusammenfassung des Artikels."},{"name":"author","typ":"string","beschreibung":"Autor:in in der Byline."},{"name":"datetime","typ":"string","beschreibung":"Zeitstempel in der Byline."}];
