	const patternCssCode = `/*
 * Hero („Aufmacher") — originalgetreue Kopie der auf zeit.de ausgelieferten
 * \`.zon-teaser\`-Regeln. Quelle: live von https://www.zeit.de/index geladene
 * Stylesheets (29 CSS-Dateien, abgerufen 2026-07-21). Klassennamen und
 * Deklarationen sind NICHT erfunden — jede Regel unten steht so (bzw. als
 * Breakpoint-Zweig, s. u.) im Produktions-CSS.
 *
 * RESPONSIVE: die Figma-Achse „Size" IST der Breakpoint.
 *
 * Was in Figma als zwei Varianten (Small/Wide) modelliert ist, ist in Produktion
 * KEIN Modifier, sondern derselbe Klassensatz an einer einzigen Grenze: \`48em\`
 * (= 768 px bei 16 px Wurzelschrift). Genau das steht jetzt als \`@media\` hier —
 * vorher verbot die Exporter-Regel jede At-Rule, weshalb nur die Desktop-Werte
 * dastanden und die Small-Stufe rein textlich im model.json behauptet wurde.
 *
 * Belegt aus dem ausgelieferten CSS (web.core/centerpage) UND nachgemessen an
 * der echten Aufmacher-Instanz auf zeit.de/index bei 375, 767, 768, 1024, 1280
 * und 1440 px. 375 und 767 liefern identische Werte, 768 und aufwärts ebenso.
 *
 * MOBILE-FIRST, weil die Produktion es ist: der schmale Wert steht ohne Media
 * Query, \`min-width: 48em\` hebt ihn an. Gemessen schalten drei Dinge:
 *   · Titel (--extralarge)      26 px / 31,2 px  →  34 px / 40,8 px
 *   · Abstand Bild ↔ Textspalte 16 px (space-m)  →  24 px (space-l)
 *   · Seitenrand der Textspalte 16 px            →  32 px  (--z-gap)
 *   · Bild-Seitenverhältnis     1:1 (mobile)     →  16:9 (desktop)
 *
 * NICHT breakpoint-abhängig (auch ein Ergebnis, gemessen): Spitzmarke (14 px),
 * Zusammenfassung (16/24), Byline-Schrift (14/21), die Maximalbreiten
 * (Medium 62.5rem im Lead, Textspalte 46.25rem) und alle Farbrollen.
 *
 * \`--z-ds-space-teaser\` (Abstand zum nächsten Element, gemessen 24 → 56 px)
 * schaltet in der ZDS-Kopie (static/styles-zds.css) bereits selbst bei 48em und
 * braucht deshalb hier keine eigene Regel.
 *
 * ZWEI BEWUSSTE ABWEICHUNGEN ZUR PRODUKTION:
 * 1) \`--z-gap\` ist in Produktion eine Seiten-Variable (\`:root\`), die nicht in der
 *    eingefrorenen ZDS-Kopie steht. Hier ist sie lokal am Aufmacher gesetzt —
 *    mit demselben 48em-Sprung (1rem → 2rem, gemessen).
 * 2) \`.zon-teaser__media\` bekommt hier eine neutrale Platzhalter-Fläche
 *    (background-color), weil die Doku kein Bild ausliefert. In Produktion
 *    steckt dort ein <picture>.
 */

.zon-teaser {
	color: var(--z-ds-color-text-100);
}

/* --- Size=Wide · Style=Standard (Basis des Aufmachers) --- */

.zon-teaser--wide {
	--z-gap: 1rem;
	display: flex;
	flex-direction: column;
	gap: var(--z-ds-space-m);
	margin-bottom: var(--z-ds-space-teaser);
}

/* Ab 48em rückt die Textspalte vom Bild ab (16 → 24 px) und der Seitenrand
   verdoppelt sich (16 → 32 px) — beides gemessen. */
@media screen and (min-width: 48em) {
	.zon-teaser--wide {
		--z-gap: 2rem;
		gap: var(--z-ds-space-l);
	}
}

.zon-teaser--wide .zon-teaser__media {
	margin: 0 auto;
	max-width: 55.75rem;
}

.zon-teaser--wide.zon-teaser--is-lead .zon-teaser__media {
	max-width: 62.5rem;
}

.zon-teaser--wide .zon-teaser__container {
	margin: 0 auto;
	max-width: calc(55.75rem + 2 * var(--z-gap));
	padding: 0 var(--z-gap);
	width: 100%;
}

.zon-teaser--wide .zon-teaser__container > * {
	max-width: 46.25rem;
}

.zon-teaser--wide .zon-teaser__container > *:first-child {
	margin-top: 0;
}

/* --- Bestandteile --- */

.zon-teaser__media {
	height: auto;
	position: relative;
	width: 100%;
	background-color: var(--z-ds-color-background-10);
}

/* Das Markup trägt in Produktion IMMER beide Formatklassen (am Aufmacher
   gemessen: \`--desktop-wide --mobile-square\`), je Seite der 48em-Grenze greift
   genau eine. Der Aufmacher wird also schmal QUADRATISCH, nicht nur kleiner. */

@media screen and (max-width: 47.999em) {
	.zon-teaser__media--mobile-square {
		aspect-ratio: 1/1;
	}
}

@media screen and (min-width: 48em) {
	.zon-teaser__media--desktop-wide {
		aspect-ratio: 16/9;
	}
}

.zon-teaser__media-container {
	width: 100%;
}

.zon-teaser__container {
	display: flex;
	flex-direction: column;
	max-width: 46.25rem;
}

.zon-teaser__heading {
	margin: 0;
	text-wrap: pretty;
}

.zon-teaser__kicker {
	align-items: center;
	color: var(--z-ds-color-accent-100);
	display: flex;
	font-size: var(--z-ds-fontsize-14);
	font-weight: normal;
	gap: var(--z-ds-space-4);
	line-height: normal;
	margin-bottom: var(--z-ds-space-xxxs);
}

/* Grundgröße des Titels (ohne --extralarge): 20 px schmal, 22 px ab 48em. */
.zon-teaser__title {
	color: var(--z-ds-color-text-100);
	display: block;
	font-size: var(--z-ds-fontsize-20);
	line-height: var(--z-ds-lineheight-12);
}

@media screen and (min-width: 48em) {
	.zon-teaser__title {
		font-size: var(--z-ds-fontsize-22);
	}
}

/* Die Aufmacher-Größe: 26 px / 31,2 px schmal, 34 px / 40,8 px ab 48em (gemessen).
   Die Zeilenhöhe bleibt lineheight-12 — es ändert sich allein der Schriftgrad. */
.zon-teaser__title--extralarge {
	font-size: var(--z-ds-fontsize-26);
}

@media screen and (min-width: 48em) {
	.zon-teaser__title--extralarge {
		font-size: var(--z-ds-fontsize-34);
	}
}

.zon-teaser__summary {
	color: var(--z-ds-color-text-70);
	font-size: var(--z-ds-fontsize-16);
	line-height: var(--z-ds-lineheight-15);
	margin: var(--z-ds-space-xs) 0 0 0;
}

.zon-teaser__byline {
	color: var(--z-ds-color-text-55);
	display: flex;
	flex-wrap: wrap;
	font-size: var(--z-ds-fontsize-14);
	gap: var(--z-ds-space-xxs) var(--z-ds-space-s);
	line-height: var(--z-ds-lineheight-15);
	margin: var(--z-ds-space-xxxs) 0 0 0;
}

.zon-teaser__actions {
	color: var(--z-ds-color-text-55);
	display: flex;
	margin-top: auto;
	padding-top: var(--z-ds-space-xs);
	position: relative;
	z-index: 3;
}

/* --- Style=Centered --- */

.zon-teaser--is-centered .zon-teaser__container {
	align-items: center;
	margin: auto;
	text-align: center;
}

.zon-teaser--is-centered .zon-teaser__container > * {
	max-width: 46.25rem;
	padding-right: 0;
}

.zon-teaser--is-centered .zon-teaser__container .zon-teaser__kicker {
	justify-content: center;
}

.zon-teaser--is-centered .zon-teaser__actions {
	justify-content: center;
	width: 100%;
}

/* --- Style=Split --- */

.zon-teaser--split {
	background-color: var(--zon-teaser-split-background-color, var(--z-ds-color-general-black-100));
	display: grid;
	grid-template-columns: 1fr;
	margin: 0 auto var(--z-ds-space-teaser) auto;
	max-width: 55.75rem;
	padding: 0;
}

.zon-teaser--split.zon-teaser--is-lead {
	max-width: 62.5rem;
}

.zon-teaser--split .zon-teaser__container {
	padding: var(--z-ds-space-l) var(--z-ds-space-xl);
}

.zon-teaser--split .zon-teaser__title {
	color: var(--z-ds-color-general-white-100);
}

.zon-teaser--split .zon-teaser__summary {
	color: var(--z-ds-color-general-white-100);
}

/* --- Style=Longform --- */

.zon-teaser--tiemann .zon-teaser__title {
	font-family: ZeitTiemannSchmal, Georgia, Palatino, 'Palatino Linotype', FreeSerif, serif;
	font-size: var(--z-ds-fontsize-30);
	font-weight: normal;
	line-height: var(--z-ds-lineheight-11);
}

/* Longform-Aufmacher: 36 px schmal, 46 px ab 48em (aus dem Produktions-CSS). */
.zon-teaser--tiemann .zon-teaser__title--extralarge {
	font-size: var(--z-ds-fontsize-36);
}

@media screen and (min-width: 48em) {
	.zon-teaser--tiemann .zon-teaser__title--extralarge {
		font-size: var(--z-ds-fontsize-46);
	}
}

/*
 * Style=Background Image ist in diesem Durchgang BEWUSST NICHT enthalten.
 * Grund: die Klasse sitzt in Produktion nicht auf dem <article>, sondern auf dem
 * Textcontainer (Modifier "on-image" auf zon-teaser__container, plus die Custom
 * Property --overlay-background-color pro Artikel). Der Playground setzt
 * Modifier ausschließlich auf das Wurzelelement — der Stil ließe sich hier also
 * nicht ehrlich rendern, nur behaupten. Er ist im Bericht als offener Punkt
 * benannt und braucht ein \`render.specimen\` (Specimen.svelte) statt \`template\`.
 */

/* --- Panorama=True (randlos, volle Breite) --- */

.zon-teaser--is-panorama {
	max-width: none;
}

.zon-teaser--wide.zon-teaser--is-panorama .zon-teaser__media {
	max-width: none;
}

.zon-teaser--split.zon-teaser--is-panorama {
	max-width: none;
}
`;
