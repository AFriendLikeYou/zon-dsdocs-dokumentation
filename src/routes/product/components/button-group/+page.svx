	<h2 id="zustaende" class="section-anchor">Zustände</h2>
	<StateList states={[{"label":"inaktiv","vorhanden":true},{"label":"hover","vorhanden":true},{"label":"aktiv","vorhanden":true}]} hint="Statisch nicht darstellbar (reine Pseudoklassen) — im Playground per Interaktion sichtbar." />

	{#if spec.doDont?.do?.length || spec.doDont?.dont?.length}
