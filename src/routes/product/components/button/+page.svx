.sds-btn--primary.sds-btn--hover{ background:var(--sds-color-background-brand-hover); }
.sds-btn--neutral.sds-btn--hover{ background:var(--sds-color-background-neutral-tertiary-hover); }
.sds-btn--subtle.sds-btn--hover{ border-color:var(--sds-color-border-default-default); }`;
