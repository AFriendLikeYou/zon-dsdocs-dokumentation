}
.sds-btn--small{ padding:var(--sds-size-space-200); }
.sds-btn--primary{ background:var(--sds-color-background-brand-default); border-color:var(--sds-color-background-brand-default); color:var(--sds-color-text-brand-on-brand); }
.sds-btn--primary:hover{ background:var(--sds-color-background-brand-hover); }
.sds-btn--neutral{ background:var(--sds-color-background-neutral-tertiary); border-color:var(--sds-color-border-neutral-secondary); color:var(--sds-color-text-default-default); }
.sds-btn--neutral:hover{ background:var(--sds-color-background-neutral-tertiary-hover); }
.sds-btn--subtle{ background:transparent; border-color:transparent; color:var(--sds-color-text-default-default); }
.sds-btn--subtle:hover{ border-color:var(--sds-color-border-default-default); }
