}
.z-button--zplus:hover,
.z-button--zplus:focus {
  background-color: var(--z-ds-color-accent-70);
  color: var(--z-ds-color-general-white-100);
}
.z-button:focus-visible {
  outline: 2px solid var(--z-ds-color-focus-100);
  outline-offset: 2px;
}
.z-button:disabled {
  pointer-events: none;
  opacity: 0.5;
}
`;
