	"render": {
		"css": [
			":global(.spec-canvas .sds-btn){",
			"  --sds-color-background-brand-default:#2c2c2c;",
			"  --sds-color-background-brand-hover:#1e1e1e;",
			"  --sds-color-text-brand-on-brand:#f5f5f5;",
			"  --sds-color-background-neutral-tertiary:#e3e3e3;",
			"  --sds-color-background-neutral-tertiary-hover:#cdcdcd;",
			"  --sds-color-border-neutral-secondary:#767676;",
			"  --sds-color-text-default-default:#1e1e1e;",
			"  --sds-color-border-default-default:#d9d9d9;",
			"  --sds-color-background-disabled-default:#d9d9d9;",
			"  --sds-color-text-disabled-on-disabled:#b3b3b3;",
			"  --sds-size-space-300:12px; --sds-size-space-200:8px;",
			"  --sds-size-radius-200:8px; --sds-size-stroke-border:1px;",
			"  display:inline-flex; align-items:center; justify-content:center;",
			"  gap:var(--sds-size-space-200);",
			"  padding:var(--sds-size-space-300);",
			"  border-radius:var(--sds-size-radius-200);",
			"  border:var(--sds-size-stroke-border) solid transparent;",
			"  font:400 16px/1 'Inter',system-ui,sans-serif; cursor:pointer;",
			"}",
			":global(.spec-canvas .sds-btn--small){ padding:var(--sds-size-space-200); }",
			":global(.spec-canvas .sds-btn--primary){ background:var(--sds-color-background-brand-default); border-color:var(--sds-color-background-brand-default); color:var(--sds-color-text-brand-on-brand); }",
			":global(.spec-canvas .sds-btn--primary:hover){ background:var(--sds-color-background-brand-hover); }",
			":global(.spec-canvas .sds-btn--neutral){ background:var(--sds-color-background-neutral-tertiary); border-color:var(--sds-color-border-neutral-secondary); color:var(--sds-color-text-default-default); }",
			":global(.spec-canvas .sds-btn--neutral:hover){ background:var(--sds-color-background-neutral-tertiary-hover); }",
			":global(.spec-canvas .sds-btn--subtle){ background:transparent; border-color:transparent; color:var(--sds-color-text-default-default); }",
			":global(.spec-canvas .sds-btn--subtle:hover){ border-color:var(--sds-color-border-default-default); }",
			":global(.spec-canvas .sds-btn:disabled){ background:var(--sds-color-background-disabled-default); border-color:var(--sds-color-border-disabled-default); color:var(--sds-color-text-disabled-on-disabled); cursor:not-allowed; }",
			":global(.spec-canvas .sds-btn--primary.sds-btn--hover){ background:var(--sds-color-background-brand-hover); }",
			":global(.spec-canvas .sds-btn--neutral.sds-btn--hover){ background:var(--sds-color-background-neutral-tertiary-hover); }",
			":global(.spec-canvas .sds-btn--subtle.sds-btn--hover){ border-color:var(--sds-color-border-default-default); }"
		],
