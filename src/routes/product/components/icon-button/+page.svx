.sds-iconbtn--neutral{ background:var(--sds-color-background-default-secondary); border-color:var(--sds-color-border-default-default); color:var(--sds-color-icon-default-default); }
.sds-iconbtn--neutral:hover{ background:var(--sds-color-background-default-secondary-hover); }
.sds-iconbtn--subtle{ background:transparent; border-color:transparent; color:var(--sds-color-icon-default-default); }
.sds-iconbtn--subtle:hover{ background:var(--sds-color-background-default-default-hover); }
.sds-iconbtn:disabled{ background:var(--sds-color-background-disabled-default); border-color:var(--sds-color-border-disabled-default); color:var(--sds-color-icon-disabled-on-disabled); cursor:not-allowed; }
.sds-iconbtn--primary.sds-iconbtn--hover{ background:var(--sds-color-background-brand-hover); }
.sds-iconbtn--neutral.sds-iconbtn--hover{ background:var(--sds-color-background-default-secondary-hover); }
.sds-iconbtn--subtle.sds-iconbtn--hover{ background:var(--sds-color-background-default-default-hover); }`;
