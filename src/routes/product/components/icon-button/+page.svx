  // 'primary' | 'neutral' | 'subtle'
  export let variant = 'primary';
  export let label; // aria-label — Pflicht
<\/script>

<button class="sds-iconbtn sds-iconbtn--{variant}" type="button" aria-label={label}>
  <!-- Icon 20×20, z. B. <Star /> -->
</button>`;
