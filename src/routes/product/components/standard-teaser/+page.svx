	const playgroundControls = [{"key":"bildformat","label":"Bildformat","type":"select","default":"super","options":[{"value":"super","label":"Super (3:2)","cssClass":"zon-teaser__media--desktop-super zon-teaser__media--mobile-super"},{"value":"wide","label":"Wide (16:9)","cssClass":"zon-teaser__media--desktop-wide zon-teaser__media--mobile-wide"},{"value":"narrow","label":"Narrow (2:3)","cssClass":"zon-teaser__media--desktop-narrow zon-teaser__media--mobile-narrow"}]}] as PlaygroundControl[];
	const playgroundTemplate = `<article class="zon-teaser zon-teaser--standard"{attrs}>
